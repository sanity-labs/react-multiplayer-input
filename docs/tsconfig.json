{
  "extends": "../tsconfig.settings.json",
  "include": [
    "./.vitepress/**/*.ts",
    "./.vitepress/**/*.tsx",
    "./.vitepress/**/*.vue",
    "./.vitepress/shims.d.ts"
  ],
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "react-multiplayer-input": ["../src"]
    }
  }
}
