{
  "name": "react-multiplayer-input",
  "version": "0.0.0",
  "private": true,
  "description": "Drop-in replacement for native <input> or <textarea> that supports cursor and scroll preservation in a multiplayer/collaborative editing scenario",
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bjoerge/react-multiplayer-input.git"
  },
  "license": "MIT",
  "author": "Bjørge Næss <bjoerge@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "test",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "run-p pkg:build",
    "format": "prettier --write --cache --ignore-unknown .",
    "pkg:build": "pkg build --strict --check --clean",
    "pkg:watch": "pkg watch --strict",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false -p tsconfig.dist.json",
    "typecheck:docs": "tsc --project docs/tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "docs": "pnpm --filter docs run dev",
    "check": "run-s typecheck pkg:build test",
    "dev": "run-p pkg:watch",
    "prepublishOnly": "npm run build"
  },
  "browserslist": "extends @sanity/browserslist-config",
  "dependencies": {
    "@sanity/client": "^6.24.1",
    "@sanity/diff-match-patch": "file://./sanity-diff-match-patch-3.1.2.tgz",
    "es-toolkit": "^1.30.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@sanity/pkg-utils": "^6.12.2",
    "@sanity/prettier-config": "^1.0.3",
    "@sanity/ui": "^2.10.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/parser": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "hono": "^4.6.14",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=18"
  }
}
